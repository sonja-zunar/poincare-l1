  RowBox[{
   RowBox[{"integraln", "[", 
    RowBox[{"m_", ",", " ", "l_", ",", " ", "n_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"phi1", "[", 
      RowBox[{"x", ",", " ", "m", ",", " ", "l"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", 
       RowBox[{"1", "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", " ", "+", " ", 
             RowBox[{"4", "/", 
              RowBox[{"n", "^", "2"}]}]}], "]"}], "+", 
           RowBox[{"2", "/", "n"}]}], ")"}], "^", "2"}]}]}], "}"}]}], "]"}]}],
   ";"}], "\n", 
 RowBox[{
  RowBox[{"p", " ", "=", " ", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mmax", " ", "=", " ", "12"}], ";"}], "\n", 
 RowBox[{
