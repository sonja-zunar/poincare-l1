Cell[CellGroupData[{

Cell[TextData[{
 "\n",
 StyleBox["4.2. Computing the integers ",
  FontSize->17],
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0.5", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{m,l}^{(0.5)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],
  FontSize->17,ExpressionUUID->"91eff002-9c13-194b-8e36-cb50d33a0f75"]
}], "Subsubsection",
 CellChangeTimes->{{3.9838751465407047`*^9, 3.983875146677603*^9}, {
  3.9838752522385826`*^9, 3.9838752911263027`*^9}, {3.9838753212315807`*^9, 
  3.9838753564596157`*^9}},ExpressionUUID->"77c930a3-7fd1-d447-a36c-\
42951f2f44e7"],

Cell[TextData[{
 "The following code constructs and prints a table ",
 StyleBox["Ntable",
  FontFamily->"Source Code Pro"],
 " of integers ",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0.5", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{m,l}^{(0.5)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "577875bf-5b0b-774d-ad19-ff471130b9dc"],
 " for ",
 StyleBox["m = ",
  FontSlant->Italic],
 "3",
 StyleBox[", ",
  FontSlant->Plain],
 "4",
 StyleBox[", ..., ",
  FontSlant->Plain],
 "12 and ",
 StyleBox["l = ",
  FontSlant->Italic],
 StyleBox["1, 2, ..., 10",
  FontSlant->Plain],
 ". "
}], "Text",
 CellChangeTimes->{{3.983451552594507*^9, 3.9834515605541763`*^9}, {
   3.9837914417358055`*^9, 3.9837915001552258`*^9}, 3.983873181319462*^9},
 FontSize->14,ExpressionUUID->"f8e27913-c938-b34e-9f08-c127a74b1c9b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", " ", "=", " ", "0.5"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lmax", " ", "=", " ", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mmax", " ", "=", " ", "12"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Ntable", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"{", 
      RowBox[{"mmax", " ", "-", " ", "2"}], "}"}], ",", " ", 
     RowBox[{"{", "lmax", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Ntable", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{"m", " ", "-", " ", "2"}], ",", " ", "l"}], "]"}], "]"}], "=",
      " ", 
     RowBox[{"smallestN", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"m", "/", "2"}], "-", " ", "1"}], ",", "0", ",", 
           RowBox[{"2", "*", " ", "Pi", "*", " ", 
            RowBox[{"l", "/", 
             RowBox[{"#", "^", "2"}]}]}]}], "]"}], " ", "<", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", "p"}], ")"}], "/", "2"}], "*", 
          RowBox[{"Gamma", "[", 
           RowBox[{
            RowBox[{"m", "/", "2"}], "-", "1"}], "]"}]}]}], " ", "&"}], ",", 
       " ", 
       RowBox[{"2", " ", "-", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "m"}]}]}], "]"}]}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"m", ",", " ", "3", ",", " ", "mmax"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"l", ",", " ", "1", ",", " ", "lmax"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"TableForm", "[", "Ntable", "]"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.983451573479292*^9, 3.9834515945918217`*^9}, {
  3.983451645041811*^9, 3.983451656759989*^9}, {3.983451707650612*^9, 
  3.983451715909544*^9}, {3.9836989826931877`*^9, 3.983698988090542*^9}, {
  3.9837913718299866`*^9, 3.983791424680361*^9}, {3.9837915049370365`*^9, 
  3.9837915054350815`*^9}},ExpressionUUID->"41b11d9d-1bd6-7a4f-930b-\
3d2964e9cde0"],

