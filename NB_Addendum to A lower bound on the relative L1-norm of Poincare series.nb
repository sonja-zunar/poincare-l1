  3.9838752447011547`*^9}},ExpressionUUID->"f7eda2d0-bff1-3f4d-a932-\
ff58b2945490"],

Cell[TextData[{
 "The following code constructs and prints a table ",
 StyleBox["Ntable1",
  FontFamily->"Source Code Pro"],
 " of integers ",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{"1", ",", 
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0.9", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{1,m,l}^{(0.9)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "e2fafa34-b3ed-544e-906b-a2f03c5465ce"],
 " for ",
 StyleBox["m = ",
  FontSlant->Italic],
 "3",
 StyleBox[", ",
  FontSlant->Plain],
 "4",
 StyleBox[", ..., ",
  FontSlant->Plain],
 "12 and ",
 StyleBox["l = ",
  FontSlant->Italic],
 StyleBox["0, 1, ..., ",
  FontSlant->Plain],
 "10.  "
}], "Text",
 CellChangeTimes->{{3.9836991590635796`*^9, 3.9836992181114025`*^9}, {
  3.9837011206047497`*^9, 3.9837011244957275`*^9}, {3.983787663985737*^9, 
  3.9837876674653645`*^9}, {3.9838733704773617`*^9, 3.983873374318344*^9}},
 FontSize->14,ExpressionUUID->"7b61f65e-df54-9d49-812d-3bb0231be062"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"phi1", "[", 
    RowBox[{"x_", ",", " ", "m_", ",", " ", "l_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"x", "^", 
     RowBox[{"(", 
      RowBox[{"l", " ", "/", " ", "2"}], ")"}]}], " ", "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", "x"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"m", " ", "/", " ", "2"}], " ", "-", " ", "2"}], ")"}]}]}]}], 
  ";"}], "\n", 
