Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"phi1", "[", 
    RowBox[{"x_", ",", " ", "m_", ",", " ", "l_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"x", "^", 
     RowBox[{"(", 
      RowBox[{"l", " ", "/", " ", "2"}], ")"}]}], " ", "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", "x"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"m", " ", "/", " ", "2"}], " ", "-", " ", "2"}], ")"}]}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"integral", "[", 
    RowBox[{"m_", ",", " ", "l_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"phi1", "[", 
      RowBox[{"x", ",", " ", "m", ",", " ", "l"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"integraln", "[", 
    RowBox[{"m_", ",", " ", "l_", ",", " ", "n_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"phi1", "[", 
      RowBox[{"x", ",", " ", "m", ",", " ", "l"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", 
       RowBox[{"1", "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", " ", "+", " ", 
             RowBox[{"4", "/", 
              RowBox[{"n", "^", "2"}]}]}], "]"}], "+", 
           RowBox[{"2", "/", "n"}]}], ")"}], "^", "2"}]}]}], "}"}]}], "]"}]}],
   ";"}], "\n", 
 RowBox[{
  RowBox[{"p", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mmax", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lmax", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ntable1", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"{", 
      RowBox[{"mmax", " ", "-", " ", "2"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"lmax", " ", "+", " ", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"rhs", " ", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"p", " ", "+", " ", "1"}], ")"}], "/", "2"}], "*", 
       RowBox[{"integral", "[", 
        RowBox[{"m", ",", " ", "l"}], "]"}]}]}], ";", "\n", 
     RowBox[{
      RowBox[{"Ntable1", "\[LeftDoubleBracket]", 
       RowBox[{
        RowBox[{"m", " ", "-", " ", "2"}], ",", 
        RowBox[{"l", " ", "+", " ", "1"}]}], "\[RightDoubleBracket]"}], "=", 
      " ", 
      RowBox[{"smallestN", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Re", "[", 
           RowBox[{"integraln", "[", 
            RowBox[{"m", ",", " ", "l", ",", " ", "#"}], "]"}], "]"}], " ", ">",
           " ", "rhs"}], " ", "&"}], ",", " ", "3"}], "]"}]}]}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"m", ",", " ", "3", ",", " ", "mmax"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"l", ",", " ", "0", ",", " ", "lmax"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"TableForm", "[", "Ntable1", "]"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9836992243025894`*^9, 3.983699245954447*^9}, {
  3.98370114341411*^9, 3.9837011439816456`*^9}, {3.983785634667904*^9, 
  3.9837856714915504`*^9}, {3.983876007882374*^9, 
  3.9838760330322742`*^9}},ExpressionUUID->"50347b70-ae6b-ce47-bb66-\
a2a7dba72ec6"],

