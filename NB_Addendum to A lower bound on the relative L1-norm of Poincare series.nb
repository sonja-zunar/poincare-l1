Cell[TextData[{
 "\n",
 StyleBox["2.3. Computing the integers ",
  FontSize->17],
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{"1", ",", 
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0.9", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{1,m,l}^{(0.9)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],
  FontSize->17,ExpressionUUID->"969fa35c-2673-0f4f-8ccb-2d29a3957f48"]
}], "Subsubsection",
