Cell[BoxData[{
 RowBox[{
  RowBox[{"phi2", "[", 
   RowBox[{"x_", ",", " ", "y_", ",", " ", "m_", ",", " ", "l_"}], "]"}], " ",
   ":=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", " ", "y"}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"l", " ", "/", " ", "2"}], ")"}]}], "*", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", "x"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", "y"}], ")"}]}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", " ", "/", " ", "2"}], " ", "-", " ", "3"}], ")"}]}], " ", "*", 
   RowBox[{"(", 
    RowBox[{"x", " ", "-", " ", "y"}], ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"integral2", "[", 
   RowBox[{"m_", ",", " ", "l_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"phi2", "[", 
     RowBox[{"x", ",", " ", "y", ",", " ", "m", ",", " ", "l"}], "]"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"y", ",", " ", "0", ",", " ", "x"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"integral2n", "[", 
   RowBox[{"m_", ",", " ", "l_", ",", " ", "n_"}], "]"}], " ", ":=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"phi2", "[", 
     RowBox[{"x", ",", " ", "y", ",", " ", "m", ",", " ", "l"}], "]"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "0", ",", 
      RowBox[{"1", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", " ", "+", " ", 
            RowBox[{"8", "/", 
             RowBox[{"n", "^", "2"}]}]}], "]"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"Sqrt", "[", "8", "]"}], "/", "n"}]}], ")"}], "^", 
        "2"}]}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"y", ",", " ", "0", ",", " ", "x"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"p", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mmax", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lmax", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ntable2", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"{", 
      RowBox[{"mmax", " ", "-", " ", "4"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"lmax", " ", "+", " ", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"rhs", " ", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"p", " ", "+", " ", "1"}], ")"}], "/", "2"}], "*", 
       RowBox[{"integral2", "[", 
        RowBox[{"m", ",", " ", "l"}], "]"}]}]}], ";", "\n", 
     RowBox[{
      RowBox[{"Ntable2", "\[LeftDoubleBracket]", 
       RowBox[{
        RowBox[{"m", " ", "-", " ", "4"}], ",", " ", 
        RowBox[{"l", " ", "+", " ", "1"}]}], "\[RightDoubleBracket]"}], "=", 
      " ", 
      RowBox[{"smallestN", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Re", "[", 
           RowBox[{"integral2n", "[", 
            RowBox[{"m", ",", " ", "l", ",", " ", "#"}], "]"}], "]"}], " ", ">",
           " ", "rhs"}], " ", "&"}], ",", " ", "3"}], "]"}]}]}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"m", ",", " ", "5", ",", " ", "mmax"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"l", ",", " ", "0", ",", " ", "lmax"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"TableForm", "[", "Ntable2", "]"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9834517010458317`*^9, 3.983451703621113*^9}, {
  3.983708163211668*^9, 3.9837081890067463`*^9}, {3.983763453538019*^9, 
  3.9837634539237823`*^9}, {3.9837861076271667`*^9, 3.9837861306871147`*^9}, {
  3.983876543423916*^9, 
  3.983876546073969*^9}},ExpressionUUID->"cbb4abe0-bb6f-a34f-bb53-\
087da125ad58"],

