Cell[CellGroupData[{

Cell[TextData[{
 "\n",
 "4",
 ".",
 " ",
 "Computing",
 " ",
 "the",
 " ",
 "integers",
 " ",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", 
         StyleBox["p", "TI"], ")"}]], TraditionalForm], "errors" -> {}, 
    "input" -> "$N_{m,l}^{(p)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "b2772b8f-a06a-bd41-bcec-705f310f8769"]
}], "Subsubsection",ExpressionUUID->"714958c4-0370-4d98-b53f-d061387e4324"],

Cell[TextData[{
 "Given ",
 StyleBox["p",
  FontSlant->Italic],
 " \[Element] [0, 1[, the code below constructs and prints a table ",
 StyleBox["Ntable",
  FontFamily->"Source Code Pro"],
 " of integers ",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", 
         StyleBox["p", "TI"], ")"}]], TraditionalForm], "errors" -> {}, 
    "input" -> "$N_{m,l}^{(p)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "ec6fd2f5-1057-b54e-9d2c-19f7d4c1bd0c"],
 " for ",
 StyleBox["l = ",
  FontSlant->Italic],
 StyleBox["1, 2, ..., ",
  FontSlant->Plain],
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubscriptBox[
       StyleBox["l", "TI"], 
       StyleBox["max", FontSlant -> "Plain"]], TraditionalForm], 
    "errors" -> {}, "input" -> "$l_{\\mathrm{max}}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "1d7b680a-9d5c-de4a-a93c-642247d006b4"],
 " and ",
 StyleBox["m = ",
  FontSlant->Italic],
 "3",
 StyleBox[", ",
  FontSlant->Plain],
 "4",
 StyleBox[", ..., ",
  FontSlant->Plain],
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["max", FontSlant -> "Plain"]], TraditionalForm], 
    "errors" -> {}, "input" -> "$m_{\\mathrm{max}}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "9e75254a-537c-394d-af49-566969416f65"],
 ". The three occurrences of the symbol \[CloverLeaf] in the code should be \
replaced with the actual values of ",
 StyleBox["p",
  FontSlant->Italic],
 ",",
 StyleBox[" ",
  FontSlant->Plain],
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubscriptBox[
       StyleBox["l", "TI"], 
       StyleBox["max", FontSlant -> "Plain"]], TraditionalForm], 
    "errors" -> {}, "input" -> "$l_{\\mathrm{max}}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "c54d9add-b755-524c-a4df-082f873d1fe5"],
 " and",
 StyleBox[" ",
  FontSlant->Plain],
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["max", FontSlant -> "Plain"]], TraditionalForm], 
    "errors" -> {}, "input" -> "$m_{\\mathrm{max}}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "7499561b-c50f-5441-8c85-818c5599f946"],
 "."
}], "Text",
 CellChangeTimes->{{3.983451552594507*^9, 3.9834515605541763`*^9}},
 FontSize->14,ExpressionUUID->"edef7312-cdf7-634e-8ffa-4644d8509fec"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lmax", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mmax", " ", "=", " ", "\[CloverLeaf]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Ntable", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"{", 
      RowBox[{"mmax", " ", "-", " ", "2"}], "}"}], ",", " ", 
     RowBox[{"{", "lmax", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Ntable", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{"m", " ", "-", " ", "2"}], ",", " ", "l"}], "]"}], "]"}], "=",
      " ", 
     RowBox[{"smallestN", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"m", "/", "2"}], "-", " ", "1"}], ",", "0", ",", 
           RowBox[{"2", "*", " ", "Pi", "*", " ", 
            RowBox[{"l", "/", 
             RowBox[{"#", "^", "2"}]}]}]}], "]"}], " ", "<", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", "p"}], ")"}], "/", "2"}], "*", 
          RowBox[{"Gamma", "[", 
           RowBox[{
            RowBox[{"m", "/", "2"}], "-", "1"}], "]"}]}]}], " ", "&"}], ",", 
       " ", 
       RowBox[{"2", " ", "-", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "m"}]}]}], "]"}]}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"m", ",", " ", "3", ",", " ", "mmax"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"l", ",", " ", "1", ",", " ", "lmax"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"TableForm", "[", "Ntable", "]"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.983451573479292*^9, 3.9834515945918217`*^9}, {
  3.983451645041811*^9, 3.983451656759989*^9}, {3.983451707650612*^9, 
  3.983451715909544*^9}, {3.9836989826931877`*^9, 3.983698988090542*^9}, {
  3.9837913718299866`*^9, 3.983791424680361*^9}, {3.983876618671051*^9, 
  3.983876624072899*^9}},ExpressionUUID->"8dd4d669-2d86-4d4b-8076-\
a78890abedd6"],

