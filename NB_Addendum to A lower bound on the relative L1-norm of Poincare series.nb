Cell[CellGroupData[{

Cell[TextData[{
 "\n",
 StyleBox["3.3. Computing the integers ",
  FontSize->17],
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{"2", ",", 
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0.9", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{2,m,l}^{(0.9)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],
  FontSize->17,ExpressionUUID->"42cb02df-db9e-4444-bbb6-08ba667799ad"]
}], "Subsubsection",
 CellChangeTimes->{{3.9838751465407047`*^9, 3.983875146677603*^9}, {
  3.9838752522385826`*^9, 3.9838752911263027`*^9}, {3.9838753212315807`*^9, 
  3.9838753214177074`*^9}},ExpressionUUID->"4e172dc5-309d-1644-ae28-\
b75f95562483"],

Cell[TextData[{
 "The following code constructs and prints a table ",
 StyleBox["Ntable2",
  FontFamily->"Source Code Pro"],
 " of integers ",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{"2", ",", 
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0.9", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{2,m,l}^{(0.9)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "b660c9f8-06b8-8042-b231-31d9a7655f09"],
 " for ",
 StyleBox["m = ",
  FontSlant->Italic],
 StyleBox["5, 6, ..., ",
  FontSlant->Plain],
 Cell[BoxData["14"],ExpressionUUID->"724fac28-f3ee-c047-bf7a-2606b255b339"],
 " and ",
 StyleBox["l = ",
  FontSlant->Italic],
 StyleBox["0, 1, ..., ",
  FontSlant->Plain],
 Cell[BoxData["10"],ExpressionUUID->"c006e047-7184-8e4d-ab96-a078bddbde5c"],
 ". "
}], "Text",
 CellChangeTimes->{{3.983708123876938*^9, 3.983708159680155*^9}, {
   3.983763653299017*^9, 3.9837637102646713`*^9}, 3.98376417039678*^9, {
   3.9837864251700077`*^9, 3.983786431925661*^9}},
 FontSize->14,ExpressionUUID->"8b3210d7-9859-df47-9757-cd259af05ebf"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"phi2", "[", 
   RowBox[{"x_", ",", " ", "y_", ",", " ", "m_", ",", " ", "l_"}], "]"}], " ",
   ":=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", " ", "y"}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"l", " ", "/", " ", "2"}], ")"}]}], "*", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", "x"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", "y"}], ")"}]}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", " ", "/", " ", "2"}], " ", "-", " ", "3"}], ")"}]}], " ", "*", 
   RowBox[{"(", 
    RowBox[{"x", " ", "-", " ", "y"}], ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"integral2", "[", 
   RowBox[{"m_", ",", " ", "l_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"phi2", "[", 
     RowBox[{"x", ",", " ", "y", ",", " ", "m", ",", " ", "l"}], "]"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"y", ",", " ", "0", ",", " ", "x"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"integral2n", "[", 
   RowBox[{"m_", ",", " ", "l_", ",", " ", "n_"}], "]"}], " ", ":=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"phi2", "[", 
     RowBox[{"x", ",", " ", "y", ",", " ", "m", ",", " ", "l"}], "]"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "0", ",", 
      RowBox[{"1", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", " ", "+", " ", 
            RowBox[{"8", "/", 
             RowBox[{"n", "^", "2"}]}]}], "]"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"Sqrt", "[", "8", "]"}], "/", "n"}]}], ")"}], "^", 
        "2"}]}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"y", ",", " ", "0", ",", " ", "x"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"p", " ", "=", " ", "0.9"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mmax", " ", "=", " ", "14"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lmax", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ntable2", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", "  ", 
     RowBox[{"{", 
      RowBox[{"mmax", " ", "-", " ", "4"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"lmax", " ", "+", " ", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"rhs", " ", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"p", " ", "+", " ", "1"}], ")"}], "/", "2"}], "*", 
       RowBox[{"integral2", "[", 
        RowBox[{"m", ",", " ", "l"}], "]"}]}]}], ";", "\n", 
     RowBox[{
      RowBox[{"Ntable2", "\[LeftDoubleBracket]", " ", 
       RowBox[{
        RowBox[{"m", " ", "-", " ", "4"}], ",", 
        RowBox[{"l", " ", "+", " ", "1"}]}], "\[RightDoubleBracket]"}], "=", 
      " ", 
      RowBox[{"smallestN", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Re", "[", 
           RowBox[{"integral2n", "[", 
            RowBox[{"m", ",", " ", "l", ",", " ", "#"}], "]"}], "]"}], " ", ">",
           " ", "rhs"}], " ", "&"}], ",", " ", "3"}], "]"}]}]}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"m", ",", " ", "5", ",", " ", "mmax"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"l", ",", " ", "0", ",", " ", "lmax"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"TableForm", "[", "Ntable2", "]"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9834517010458317`*^9, 3.983451703621113*^9}, {
  3.983708163211668*^9, 3.9837081890067463`*^9}, {3.983763453538019*^9, 
  3.9837634539237823`*^9}, {3.983764182119631*^9, 3.983764192239271*^9}, {
  3.983777325894781*^9, 3.9837773266059513`*^9}, {3.983786409724556*^9, 
  3.9837864202034664`*^9}, {3.983786456986582*^9, 3.9837865281957607`*^9}, {
  3.9837877408613796`*^9, 3.983787747367237*^9}, {3.9837913461241913`*^9, 
  3.983791349144724*^9}, {3.983806990303999*^9, 3.983806993197056*^9}, {
  3.983852079367981*^9, 3.9838520805464344`*^9}, {3.983873267652748*^9, 
