Cell[TextData[{
 "The following code constructs and prints a table ",
 StyleBox["Ntable",
  FontFamily->"Source Code Pro"],
 " of integers ",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0.9", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{m,l}^{(0.9)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "26b7c603-5af9-fd40-ada5-95804ea4d342"],
 " for ",
 StyleBox["m = ",
  FontSlant->Italic],
 "3",
 StyleBox[", ",
  FontSlant->Plain],
 "4",
 StyleBox[", ..., ",
  FontSlant->Plain],
 "12 and ",
 StyleBox["l = ",
  FontSlant->Italic],
 StyleBox["1, 2, ..., 10",
  FontSlant->Plain],
 ". "
}], "Text",
 CellChangeTimes->{{3.983451552594507*^9, 3.9834515605541763`*^9}, {
   3.9837914417358055`*^9, 3.9837915001552258`*^9}, 3.9838731861355705`*^9},
 FontSize->14,ExpressionUUID->"b796b4f7-349d-2b4e-b24c-85940a2b1c4c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", " ", "=", " ", "0.9"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lmax", " ", "=", " ", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mmax", " ", "=", " ", "12"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Ntable", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"{", 
      RowBox[{"mmax", " ", "-", " ", "2"}], "}"}], ",", " ", 
     RowBox[{"{", "lmax", "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Ntable", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{"m", " ", "-", " ", "2"}], ",", " ", "l"}], "]"}], "]"}], "=",
      " ", 
     RowBox[{"smallestN", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"m", "/", "2"}], "-", " ", "1"}], ",", "0", ",", 
           RowBox[{"2", "*", " ", "Pi", "*", " ", 
            RowBox[{"l", "/", 
             RowBox[{"#", "^", "2"}]}]}]}], "]"}], " ", "<", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "-", "p"}], ")"}], "/", "2"}], "*", 
          RowBox[{"Gamma", "[", 
           RowBox[{
            RowBox[{"m", "/", "2"}], "-", "1"}], "]"}]}]}], " ", "&"}], ",", 
       " ", 
       RowBox[{"2", " ", "-", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", "m"}]}]}], "]"}]}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"m", ",", " ", "3", ",", " ", "mmax"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"l", ",", " ", "1", ",", " ", "lmax"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"TableForm", "[", "Ntable", "]"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.983451573479292*^9, 3.9834515945918217`*^9}, {
  3.983451645041811*^9, 3.983451656759989*^9}, {3.983451707650612*^9, 
  3.983451715909544*^9}, {3.9836989826931877`*^9, 3.983698988090542*^9}, {
  3.9837913718299866`*^9, 3.983791424680361*^9}, {3.9837915049370365`*^9, 
  3.983791533685541*^9}},ExpressionUUID->"5d6763d9-21d4-b64e-9cf8-\
b9b33a7cec98"],

