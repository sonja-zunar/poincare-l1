Cell[TextData[{
 "The following code constructs and prints a table ",
 StyleBox["Ntable1",
  FontFamily->"Source Code Pro"],
 " of integers ",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{"1", ",", 
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0.5", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{1,m,l}^{(0.5)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "1b79188c-4e8c-d14b-a9bc-c5eb2b45a789"],
 " for ",
 StyleBox["m = ",
  FontSlant->Italic],
 "3",
 StyleBox[", ",
  FontSlant->Plain],
 "4",
 StyleBox[", ..., ",
  FontSlant->Plain],
 "12 and ",
 StyleBox["l = ",
  FontSlant->Italic],
 StyleBox["0, 1, ..., ",
  FontSlant->Plain],
 "10. "
}], "Text",
