  RowBox[{"mid", "[", 
   RowBox[{"low_", ",", " ", "high_"}], "]"}], " ", ":=", " ", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"high", " ", "\[Equal]", " ", "Infinity"}], ",", " ", 
    RowBox[{"2", " ", "*", " ", "low"}], ",", " ", 
    RowBox[{"Floor", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"low", " ", "+", " ", "high"}], ")"}], " ", "/", " ", "2"}], 
     "]"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"binarySearch", "[", 
   RowBox[{"f_", ",", " ", "low_", ",", " ", "high_"}], "]"}], " ", ":=", " ", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"low", " ", "\[Equal]", " ", "high"}], ",", " ", "high", ",", " ", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"f", "[", 
