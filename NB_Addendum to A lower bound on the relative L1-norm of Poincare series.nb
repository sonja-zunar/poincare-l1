    "$N_{2,m,l}^{(0)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],
  FontSize->17,ExpressionUUID->"ed19c0a0-fde4-7f41-844f-eccd47eace3b"]
}], "Subsubsection",
 CellChangeTimes->{{3.9838751465407047`*^9, 3.983875146677603*^9}, {
  3.9838752522385826`*^9, 3.983875252285755*^9}, {3.983875284373131*^9, 
  3.9838752856762047`*^9}},ExpressionUUID->"83e06cd2-efe2-9f47-9dee-\
f978888913ea"],

Cell[TextData[{
 "The code below constructs and prints a table ",
 StyleBox["Ntable2",
  FontFamily->"Source Code Pro"],
 " of integers ",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      SubsuperscriptBox[
       StyleBox["N", "TI"], 
       RowBox[{"2", ",", 
         StyleBox["m", "TI"], ",", 
         StyleBox["l", "TI"]}], 
       RowBox[{"(", "0", ")"}]], TraditionalForm], "errors" -> {}, "input" -> 
    "$N_{2,m,l}^{(0)}$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]],ExpressionUUID->
  "acb7cbff-b805-314b-b4fb-bbf6686aec1e"],
 " for ",
 StyleBox["m = ",
  FontSlant->Italic],
 StyleBox["5, 6, ..., 14",
  FontSlant->Plain],
 " and ",
 StyleBox["l = ",
  FontSlant->Italic],
 StyleBox["0, 1, ..., 10",
  FontSlant->Plain],
 ". "
}], "Text",
 CellChangeTimes->{{3.983708123876938*^9, 3.983708159680155*^9}, {
  3.9838733403181095`*^9, 3.9838733475708904`*^9}, {3.9838745667854424`*^9, 
  3.9838745722298813`*^9}},
 FontSize->14,ExpressionUUID->"3e19b0b6-e4e8-4e7e-ac4a-635603b0b9d8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"phi2", "[", 
   RowBox[{"x_", ",", " ", "y_", ",", " ", "m_", ",", " ", "l_"}], "]"}], " ",
   ":=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", " ", "y"}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"l", " ", "/", " ", "2"}], ")"}]}], "*", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", "x"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", "y"}], ")"}]}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", " ", "/", " ", "2"}], " ", "-", " ", "3"}], ")"}]}], " ", "*", 
   RowBox[{"(", 
    RowBox[{"x", " ", "-", " ", "y"}], ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"integral2", "[", 
   RowBox[{"m_", ",", " ", "l_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"phi2", "[", 
     RowBox[{"x", ",", " ", "y", ",", " ", "m", ",", " ", "l"}], "]"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"y", ",", " ", "0", ",", " ", "x"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"integral2n", "[", 
   RowBox[{"m_", ",", " ", "l_", ",", " ", "n_"}], "]"}], " ", ":=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"phi2", "[", 
     RowBox[{"x", ",", " ", "y", ",", " ", "m", ",", " ", "l"}], "]"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "0", ",", 
      RowBox[{"1", "/", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", " ", "+", " ", 
            RowBox[{"8", "/", 
             RowBox[{"n", "^", "2"}]}]}], "]"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"Sqrt", "[", "8", "]"}], "/", "n"}]}], ")"}], "^", 
        "2"}]}]}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"y", ",", " ", "0", ",", " ", "x"}], "}"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"p", " ", "=", " ", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mmax", " ", "=", " ", "14"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lmax", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ntable2", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"{", 
      RowBox[{"mmax", " ", "-", " ", "4"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"lmax", " ", "+", " ", "1"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"rhs", " ", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"p", " ", "+", " ", "1"}], ")"}], "/", "2"}], "*", 
       RowBox[{"integral2", "[", 
        RowBox[{"m", ",", " ", "l"}], "]"}]}]}], ";", "\n", 
     RowBox[{
      RowBox[{"Ntable2", "\[LeftDoubleBracket]", 
       RowBox[{
        RowBox[{"m", " ", "-", " ", "4"}], ",", " ", 
        RowBox[{"l", " ", "+", " ", "1"}]}], "\[RightDoubleBracket]"}], "=", 
      " ", 
      RowBox[{"smallestN", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Re", "[", 
           RowBox[{"integral2n", "[", 
            RowBox[{"m", ",", " ", "l", ",", " ", "#"}], "]"}], "]"}], " ", ">",
           " ", "rhs"}], " ", "&"}], ",", " ", "3"}], "]"}]}]}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"m", ",", " ", "5", ",", " ", "mmax"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"l", ",", " ", "0", ",", " ", "lmax"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"TableForm", "[", "Ntable2", "]"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9834517010458317`*^9, 3.983451703621113*^9}, {
  3.983708163211668*^9, 3.9837081890067463`*^9}, {3.983763453538019*^9, 
  3.9837634539237823`*^9}, {3.9837861076271667`*^9, 
  3.9837861306871147`*^9}},ExpressionUUID->"d70e273f-9e98-416d-b929-\
5bcf34b78adb"],

